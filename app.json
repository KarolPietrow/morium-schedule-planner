{
  "expo": {
    "name": "Morium",
    "slug": "morium",
    "version": "0.2.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "morium",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/morium-icon-ios.icon",
      "bundleIdentifier": "pl.karolpietrow.morium",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "pl.karolpietrow.morium",
      "userInterfaceStyle": "automatic"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/icon.png",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ],
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3cfdb2ad-8c1b-486b-85c0-f2963146d9de"
      }
    }
  }
}
